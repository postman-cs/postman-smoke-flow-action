{
  "name": "@postman-cse/onboarding-smoke-flow",
  "version": "2.1.0",
  "description": "GitHub Action and CLI for applying curated Postman Smoke collection flows.",
  "type": "module",
  "main": "dist/main.cjs",
  "bin": {
    "postman-smoke-flow": "dist/cli.cjs"
  },
  "files": [
    "action.yml",
    "dist"
  ],
  "scripts": {
    "prepare": "git config core.hooksPath .githooks",
    "build": "npm run typecheck && rm -rf dist && esbuild src/main.ts --bundle --platform=node --target=node24 --format=cjs --outfile=dist/main.cjs && esbuild src/cli.ts --bundle --platform=node --target=node24 --format=cjs --banner:js='#!/usr/bin/env node' --outfile=dist/cli.cjs",
    "verify:dist": "npm run build && git diff --ignore-space-at-eol --text --exit-code -- dist",
    "docs:tables": "node scripts/render-action-tables.mjs",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "test": "vitest run",
    "typecheck": "tsc --noEmit -p tsconfig.json"
  },
  "keywords": [
    "api-onboarding",
    "github-action",
    "postman",
    "smoke-testing"
  ],
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@actions/core": "^3.0.1",
    "@postman-cse/automation-telemetry-core": "^0.2.0",
    "undici": "^6.24.0",
    "yaml": "^2.9.0"
  },
  "overrides": {
    "undici": "^6.24.0",
    "picomatch": ">=4.0.4"
  },
  "devDependencies": {
    "@commitlint/cli": "^21.2.0",
    "@commitlint/config-conventional": "^21.2.0",
    "@eslint/js": "^10.0.1",
    "@types/node": "^26.1.0",
    "esbuild": "0.28.1",
    "eslint": "^10.4.1",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.60.0",
    "vitest": "^4.1.7"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/postman-cs/postman-smoke-flow-action"
  },
  "engines": {
    "node": ">=24"
  }
}
